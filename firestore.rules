
/**
 * TurnosYa - Firestore Security Rules
 * Configured for multi-tenant salon management and public booking.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isGlobalAdmin() {
      // Verificación maestra: el UID del usuario debe existir en la colección globalAdmins
      return isSignedIn() && exists(/databases/$(database)/documents/globalAdmins/$(request.auth.uid));
    }

    function isSalonAdmin(salonData) {
      return isSignedIn() && (
        (salonData.keys().contains('adminMembers') && salonData.adminMembers[request.auth.uid] == true) || 
        (salonData.keys().contains('salonAdminMembers') && salonData.salonAdminMembers[request.auth.uid] == true)
      );
    }

    // --- Collection Rules ---

    match /userProfiles/{userProfileId} {
      allow get, list: if isOwner(userProfileId) || isGlobalAdmin();
      allow create, update: if isOwner(userProfileId);
      allow delete: if isOwner(userProfileId) || isGlobalAdmin();
    }

    match /globalAdmins/{userId} {
      // Permite que cualquier usuario autenticado verifique su propio permiso
      allow get: if isSignedIn() && request.auth.uid == userId;
      // Solo un admin global puede listar a otros admins
      allow list: if isGlobalAdmin();
      allow write: if false; 
    }

    match /salons/{salonId} {
      // Acceso público para ver detalles del negocio y reservar
      allow get, list: if true; 
      
      // Solo usuarios registrados pueden crear un salón
      allow create: if isSignedIn(); 
      
      // Solo el dueño del salón o el Admin Global pueden editar/borrar
      allow update, delete: if resource != null && (isSalonAdmin(resource.data) || isGlobalAdmin());
      
      match /services/{serviceId} {
        allow get, list: if true; 
        allow write: if isSignedIn(); 
      }
      
      match /professionals/{professionalId} {
        allow get, list: if true;
        allow write: if isSignedIn();
      }
    }

    match /appointments/{appointmentId} {
      allow get, list: if isSignedIn() || isGlobalAdmin(); 
      allow create: if isSignedIn(); 
      allow update, delete: if isSignedIn() || isGlobalAdmin(); 
    }

    match /payments/{paymentId} {
      allow read, write: if isSignedIn();
    }

    match /reminders/{reminderId} {
      allow read, write: if isSignedIn();
    }
  }
}
