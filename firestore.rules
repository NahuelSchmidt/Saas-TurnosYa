
/**
 * TurnosYa - Firestore Security Rules
 * Configura el acceso para gestión multi-inquilino y reservas públicas.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Funciones de Ayuda ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isGlobalAdmin() {
      // Verificación maestra: el UID debe existir en globalAdmins
      return isSignedIn() && exists(/databases/$(database)/documents/globalAdmins/$(request.auth.uid));
    }

    function isSalonAdmin(salonData) {
      // Verificación robusta de administración de salón
      return isSignedIn() && (
        (salonData.get('adminMembers', {})[request.auth.uid] == true) || 
        (salonData.get('salonAdminMembers', {})[request.auth.uid] == true)
      );
    }

    // --- Reglas de Colecciones ---

    match /userProfiles/{userProfileId} {
      allow get: if isSignedIn();
      allow list: if isGlobalAdmin();
      allow create, update: if isOwner(userProfileId);
      allow delete: if isGlobalAdmin();
    }

    match /globalAdmins/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if isGlobalAdmin();
      allow write: if false; 
    }

    match /salons/{salonId} {
      // Acceso público para ver detalles y reservar
      allow get, list: if true; 
      
      // Cualquier usuario registrado puede crear un salón
      allow create: if isSignedIn(); 
      
      // Permitir actualización si es admin del salón o admin global
      allow update, delete: if (resource != null && isSalonAdmin(resource.data)) || isGlobalAdmin();
      
      match /services/{serviceId} {
        allow get, list: if true; 
        allow write: if isSignedIn(); 
      }
      
      match /professionals/{professionalId} {
        allow get, list: if true;
        allow write: if isSignedIn();
      }
    }

    match /appointments/{appointmentId} {
      allow get, list: if isSignedIn(); 
      allow create: if isSignedIn(); 
      allow update, delete: if isSignedIn(); 
    }

    match /payments/{paymentId} {
      allow read, write: if isSignedIn();
    }

    match /reminders/{reminderId} {
      allow read, write: if isSignedIn();
    }
  }
}
