
/**
 * TurnosYa - Firestore Security Rules
 * Configured for multi-tenant salon management and public booking.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isGlobalAdmin() {
      // Un usuario es admin global si su UID existe en la colección globalAdmins
      return isSignedIn() && exists(/databases/$(database)/documents/globalAdmins/$(request.auth.uid));
    }

    function isSalonAdmin(salonData) {
      return isSignedIn() && (
        (salonData.get('adminMembers', {}).get(request.auth.uid, false) == true) || 
        (salonData.get('salonAdminMembers', {}).get(request.auth.uid, false) == true)
      );
    }

    // --- Collection Rules ---

    match /userProfiles/{userProfileId} {
      allow get, list: if isOwner(userProfileId) || isGlobalAdmin();
      allow create, update: if isOwner(userProfileId);
      allow delete: if isOwner(userProfileId) || isGlobalAdmin();
    }

    match /globalAdmins/{userId} {
      // Permite que el usuario lea SU PROPIO permiso para que la App lo identifique
      allow get: if isSignedIn() && request.auth.uid == userId;
      // Solo admins pueden ver la lista de otros admins
      allow list: if isGlobalAdmin();
      // Solo editable desde consola por seguridad máxima
      allow write: if false; 
    }

    match /salons/{salonId} {
      // El listado general para el Super Admin requiere ser Super Admin
      // pero para el público permitimos 'get' si conocen el ID para reservar
      allow get: if true; 
      allow list: if isGlobalAdmin(); // Solo tú puedes ver la lista completa
      
      allow create: if isSignedIn(); 
      allow update, delete: if resource != null && (isSalonAdmin(resource.data) || isGlobalAdmin());
      
      match /services/{serviceId} {
        allow get, list: if true;
        allow write: if isSignedIn(); 
      }
      
      match /professionals/{professionalId} {
        allow get, list: if true;
        allow write: if isSignedIn();
      }
    }

    match /appointments/{appointmentId} {
      allow get, list: if isSignedIn() || isGlobalAdmin(); 
      allow create: if isSignedIn(); 
      allow update, delete: if isSignedIn() || isGlobalAdmin(); 
    }

    match /payments/{paymentId} {
      allow read, write: if isSignedIn();
    }

    match /reminders/{reminderId} {
      allow read, write: if isSignedIn();
    }
  }
}
